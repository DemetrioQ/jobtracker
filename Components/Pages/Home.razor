@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.EntityFrameworkCore
@using jobtracker.Data
@using jobtracker.Services

@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Job Tracker</PageTitle>

<div class="dashboard-grid">
    <div class="metric-card">
        <div class="metric-label">Applied this week</div>
        <div class="metric-value">@_appliedThisWeek</div>
    </div>
    <div class="metric-card @(_overdueFollowUps > 0 ? "metric-warn" : "")">
        <div class="metric-label">Pending follow-ups</div>
        <div class="metric-value">@_pendingFollowUps</div>
        @if (_overdueFollowUps > 0)
        {
            <div class="metric-sub">@_overdueFollowUps overdue</div>
        }
    </div>
    <div class="metric-card">
        <div class="metric-label">Response rate</div>
        <div class="metric-value">@_responseRate%</div>
        <div class="metric-sub">@_respondedCount of @_appliedCount</div>
    </div>
    <div class="metric-card">
        <div class="metric-label">Interviews</div>
        <div class="metric-value">@_interviewCount</div>
    </div>
</div>

<div class="job-search-bar">
    <span class="search-bar-label">Find jobs</span>
    <input @bind="_searchQuery" @bind:event="oninput"
           placeholder="Keywords (e.g., senior backend remote)…"
           class="form-control" />
    @{
        var hasQuery = !string.IsNullOrWhiteSpace(_searchQuery);
    }
    @foreach (var (key, label) in SearchProviders)
    {
        if (hasQuery)
        {
            <a class="search-provider" href="@BuildSearchUrl(key)" target="_blank" rel="noopener noreferrer">@label</a>
        }
        else
        {
            <button class="search-provider" disabled>@label</button>
        }
    }
</div>

<div class="quick-add">
    <h3>Quick add <span class="kbd">N</span></h3>
    <div class="quick-add-row">
        <input @ref="_quickCompanyRef" @bind="_qCompany" @bind:event="oninput" placeholder="Company" class="form-control" @onkeydown="QuickAddKey" />
        <input @bind="_qTitle" @bind:event="oninput" placeholder="Title" class="form-control" @onkeydown="QuickAddKey" />
        <input @bind="_qUrl" @bind:event="oninput" placeholder="URL (optional)" class="form-control" @onkeydown="QuickAddKey" />
        <select @bind="_qStatus" class="form-select status-select status-@_qStatus.ToString().ToLower()">
            @foreach (var s in Enum.GetValues<JobStatus>())
            {
                <option value="@s">@FormatStatus(s)</option>
            }
        </select>
        <button class="btn btn-primary" @onclick="QuickAdd" disabled="@(string.IsNullOrWhiteSpace(_qCompany) || string.IsNullOrWhiteSpace(_qTitle))">
            Add
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_qLocation) || !string.IsNullOrWhiteSpace(_qSalary))
    {
        <div class="extracted-extras">
            <span class="muted">Will save with:</span>
            @if (!string.IsNullOrWhiteSpace(_qLocation))
            {
                <span class="extra-pill"><strong>Location:</strong> @_qLocation</span>
            }
            @if (!string.IsNullOrWhiteSpace(_qSalary))
            {
                <span class="extra-pill"><strong>Salary:</strong> @_qSalary</span>
            }
            <button class="btn btn-link btn-tiny" @onclick="ClearExtras">clear</button>
        </div>
    }

    <div class="paste-panel @(_pasteOpen ? "open" : "")">
        <button class="paste-toggle" type="button" @onclick="() => _pasteOpen = !_pasteOpen" aria-expanded="@_pasteOpen.ToString().ToLowerInvariant()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9" />
            </svg>
            Paste a job posting
            <span class="muted">— extracts company, title, location, salary, URL</span>
        </button>
        @if (_pasteOpen)
        {
            <textarea @bind="_pasteText" @bind:event="oninput" rows="6"
                      class="form-control paste-textarea"
                      placeholder="Paste the full job posting here, then press Parse…"></textarea>
            <div class="paste-actions">
                <button class="btn btn-secondary btn-sm" @onclick="ParsePaste" disabled="@string.IsNullOrWhiteSpace(_pasteText)">Parse</button>
                <button class="btn btn-link btn-sm" @onclick="ClearPaste">Clear</button>
                @if (_lastExtraction is not null)
                {
                    <span class="muted">Parsed ✓ — review fields above and click Add</span>
                }
                <a href="/bookmarklet" class="muted paste-bookmarklet-hint">Use the bookmarklet instead →</a>
            </div>
        }
    </div>
</div>

<div class="jobs-toolbar">
    <input @bind="Search" @bind:event="oninput" placeholder="Search company / title…  (press / )" class="form-control search-input" />
    <select @bind="FilterStatus" class="form-select">
        <option value="">All statuses</option>
        @foreach (var s in Enum.GetValues<JobStatus>())
        {
            <option value="@s">@FormatStatus(s)</option>
        }
    </select>
    <span class="muted">@FilteredAndSortedJobs.Count() of @_jobs.Count</span>
</div>

<table class="jobs-table">
    <thead>
        <tr>
            <th><button class="th-sort @SortState("company")" @onclick='() => Sort("company")'>Company</button></th>
            <th><button class="th-sort @SortState("title")" @onclick='() => Sort("title")'>Title</button></th>
            <th>Location</th>
            <th><button class="th-sort @SortState("applied")" @onclick='() => Sort("applied")'>Applied</button></th>
            <th><button class="th-sort @SortState("status")" @onclick='() => Sort("status")'>Status</button></th>
            <th><button class="th-sort @SortState("followup")" @onclick='() => Sort("followup")'>Follow-up</button></th>
            <th class="th-actions">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!FilteredAndSortedJobs.Any())
        {
            <tr><td colspan="7" class="empty">@(_jobs.Count == 0 ? "No jobs yet — add one above." : "No matches.")</td></tr>
        }
        else
        {
            @foreach (var job in FilteredAndSortedJobs)
            {
                <tr class="@RowClass(job)" @onclick="() => Edit(job)">
                    <td data-label="Company">
                        <div class="company-cell">
                            @if (!string.IsNullOrWhiteSpace(job.Url) && FaviconUrl(job.Url) is { } favicon)
                            {
                                <img src="@favicon" class="favicon" alt="" loading="lazy" referrerpolicy="no-referrer" />
                            }
                            @if (!string.IsNullOrWhiteSpace(job.Url))
                            {
                                <a href="@job.Url" target="_blank" rel="noopener" @onclick:stopPropagation>@job.Company</a>
                            }
                            else
                            {
                                <span>@job.Company</span>
                            }
                        </div>
                    </td>
                    <td data-label="Title">@job.Title</td>
                    <td data-label="Location" class="muted">
                        <div class="cell-stack">
                            <div>@(string.IsNullOrWhiteSpace(job.Location) ? "—" : job.Location)</div>
                            @if (!string.IsNullOrWhiteSpace(job.Salary))
                            {
                                <div class="cell-sub">@job.Salary</div>
                            }
                        </div>
                    </td>
                    <td data-label="Applied" class="muted">@(job.DateApplied?.ToString("MMM d") ?? "—")</td>
                    <td data-label="Status" @onclick:stopPropagation>
                        <div class="status-pop @(_statusMenuJobId == job.Id ? "open" : "")">
                            <button class="status-pill status-@job.Status.ToString().ToLower()"
                                    @onclick="() => ToggleStatusMenu(job.Id)">
                                @FormatStatus(job.Status)
                                <svg viewBox="0 0 24 24" class="caret" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <polyline points="6 9 12 15 18 9" />
                                </svg>
                            </button>
                            @if (_statusMenuJobId == job.Id)
                            {
                                <ul class="status-menu" role="listbox">
                                    @foreach (var s in Enum.GetValues<JobStatus>())
                                    {
                                        <li>
                                            <button class="status-option status-@s.ToString().ToLower() @(s == job.Status ? "current" : "")"
                                                    @onclick="() => SetStatus(job, s)">
                                                @FormatStatus(s)
                                            </button>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    </td>
                    <td data-label="Follow-up" @onclick:stopPropagation>
                        <input type="date" class="form-control followup-input"
                               value="@(job.FollowUpDate?.ToString("yyyy-MM-dd"))"
                               @onchange="e => OnFollowUpChanged(job, e)" />
                    </td>
                    <td class="actions" @onclick:stopPropagation>
                        <button class="icon-btn" title="Snooze follow-up 7 days" aria-label="Snooze 7 days" @onclick="() => SnoozeFollowUp(job, 7)">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="13" r="8" />
                                <path d="M12 9v4l2.5 1.5" />
                                <path d="M5 3 2 6" />
                                <path d="m22 6-3-3" />
                            </svg>
                        </button>
                        <button class="icon-btn" title="Edit" aria-label="Edit" @onclick="() => Edit(job)">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M12 20h9" />
                                <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z" />
                            </svg>
                        </button>
                        @if (_pendingDeleteId == job.Id)
                        {
                            <button class="icon-btn icon-btn-danger delete-confirm" title="Click again to confirm delete" aria-label="Confirm delete" @onclick="() => Delete(job)">
                                Confirm?
                            </button>
                        }
                        else
                        {
                            <button class="icon-btn icon-btn-danger" title="Delete" aria-label="Delete" @onclick="() => RequestDelete(job)">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M3 6h18" />
                                    <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6" />
                                    <path d="M10 11v6M14 11v6" />
                                </svg>
                            </button>
                        }
                    </td>
                </tr>
                @if (_editingId == job.Id)
                {
                    <tr class="edit-row" @onclick:stopPropagation>
                        <td colspan="7">
                            <div class="edit-grid">
                                <label>Location <input @bind="_editJob!.Location" class="form-control" /></label>
                                <label>Salary <input @bind="_editJob!.Salary" class="form-control" /></label>
                                <label>URL <input @bind="_editJob!.Url" class="form-control" /></label>
                                <label>Recruiter <input @bind="_editJob!.RecruiterName" class="form-control" /></label>
                                <label>Recruiter email <input @bind="_editJob!.RecruiterEmail" class="form-control" /></label>
                                <label>Interview date <input type="date" @bind="_editInterviewDate" class="form-control" /></label>
                                <label>Date applied <input type="date" @bind="_editAppliedDate" class="form-control" /></label>
                                <label class="full">Notes <textarea @bind="_editJob!.Notes" class="form-control" rows="3"></textarea></label>
                            </div>
                            <div class="edit-actions">
                                <button class="btn btn-primary" @onclick="SaveEdit">Save</button>
                                <button class="btn btn-secondary" @onclick="CancelEdit">Cancel <span class="kbd">Esc</span></button>
                            </div>
                        </td>
                    </tr>
                }
            }
        }
    </tbody>
</table>

@code {
    private string? _userId;
    private List<Job> _jobs = new();

    // Quick-add fields
    private ElementReference _quickCompanyRef;
    private string _qCompany = "";
    private string _qTitle = "";
    private string _qUrl = "";
    private JobStatus _qStatus = JobStatus.Applied;
    private string? _qLocation;
    private string? _qSalary;

    // External job search
    private string _searchQuery = "";

    // Paste-to-extract
    private bool _pasteOpen;
    private string _pasteText = "";
    private ExtractedJob? _lastExtraction;

    // Search / filter (URL-bound via Search/FilterStatus properties)
    private string _search = "";
    private string _filterStatus = "";

    private string Search
    {
        get => _search;
        set { if (_search != value) { _search = value; UpdateQueryString(); } }
    }

    private string FilterStatus
    {
        get => _filterStatus;
        set { if (_filterStatus != value) { _filterStatus = value; UpdateQueryString(); } }
    }

    // Sort
    private string _sortColumn = "updated";
    private bool _sortDesc = true;

    // Inline edit
    private int? _editingId;
    private Job? _editJob;
    private DateTime? _editInterviewDate;
    private DateTime? _editAppliedDate;

    // Transient UI state
    private int? _statusMenuJobId;
    private int? _pendingDeleteId;

    // Metrics
    private int _appliedThisWeek;
    private int _pendingFollowUps;
    private int _overdueFollowUps;
    private int _appliedCount;
    private int _respondedCount;
    private int _responseRate;
    private int _interviewCount;

    private DotNetObjectReference<Home>? _selfRef;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        _userId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (_userId is null) return;

        ReadQueryString();
        ApplyPrefill();
        Nav.LocationChanged += OnLocationChanged;

        await LoadJobs();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("jobtracker.bindShortcuts", _selfRef);
        }
    }

    [JSInvokable]
    public async Task FocusQuickAdd() => await _quickCompanyRef.FocusAsync();

    [JSInvokable]
    public Task OnEscape()
    {
        var changed = false;
        if (_statusMenuJobId is not null) { _statusMenuJobId = null; changed = true; }
        if (_pendingDeleteId is not null) { _pendingDeleteId = null; changed = true; }
        if (_editingId is not null) { CancelEdit(); changed = true; }
        if (changed) StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task CloseTransients()
    {
        var changed = false;
        if (_statusMenuJobId is not null) { _statusMenuJobId = null; changed = true; }
        if (_pendingDeleteId is not null) { _pendingDeleteId = null; changed = true; }
        if (changed) StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task LoadJobs()
    {
        _jobs = await Db.Jobs
            .AsNoTracking()
            .Where(j => j.UserId == _userId)
            .ToListAsync();
        ComputeMetrics();
    }

    private void ComputeMetrics()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var weekAgo = today.AddDays(-7);

        _appliedThisWeek = _jobs.Count(j => j.DateApplied.HasValue && j.DateApplied >= weekAgo);
        _pendingFollowUps = _jobs.Count(j => j.FollowUpDate.HasValue
            && j.Status != JobStatus.Rejected && j.Status != JobStatus.Offer && j.Status != JobStatus.Withdrawn);
        _overdueFollowUps = _jobs.Count(j => j.FollowUpDate.HasValue && j.FollowUpDate < today
            && j.Status != JobStatus.Rejected && j.Status != JobStatus.Offer && j.Status != JobStatus.Withdrawn);

        _appliedCount = _jobs.Count(j => j.Status >= JobStatus.Applied && j.Status != JobStatus.Saved);
        _respondedCount = _jobs.Count(j => j.Status == JobStatus.RecruiterMessaged
            || j.Status == JobStatus.Interview || j.Status == JobStatus.Offer);
        _responseRate = _appliedCount == 0 ? 0 : (int)Math.Round(100.0 * _respondedCount / _appliedCount);
        _interviewCount = _jobs.Count(j => j.Status == JobStatus.Interview);
    }

    private IEnumerable<Job> FilteredAndSortedJobs
    {
        get
        {
            IEnumerable<Job> q = _jobs;
            if (!string.IsNullOrWhiteSpace(_search))
            {
                var s = _search.Trim();
                q = q.Where(j => j.Company.Contains(s, StringComparison.OrdinalIgnoreCase)
                              || j.Title.Contains(s, StringComparison.OrdinalIgnoreCase));
            }
            if (!string.IsNullOrEmpty(_filterStatus) && Enum.TryParse<JobStatus>(_filterStatus, out var st))
            {
                q = q.Where(j => j.Status == st);
            }

            return _sortColumn switch
            {
                "company"  => _sortDesc ? q.OrderByDescending(j => j.Company)                                  : q.OrderBy(j => j.Company),
                "title"    => _sortDesc ? q.OrderByDescending(j => j.Title)                                    : q.OrderBy(j => j.Title),
                "applied"  => _sortDesc ? q.OrderByDescending(j => j.DateApplied ?? DateOnly.MinValue)         : q.OrderBy(j => j.DateApplied ?? DateOnly.MaxValue),
                "status"   => _sortDesc ? q.OrderByDescending(j => j.Status)                                   : q.OrderBy(j => j.Status),
                "followup" => _sortDesc ? q.OrderByDescending(j => j.FollowUpDate ?? DateOnly.MinValue)        : q.OrderBy(j => j.FollowUpDate ?? DateOnly.MaxValue),
                _          => _sortDesc ? q.OrderByDescending(j => j.UpdatedAt)                                : q.OrderBy(j => j.UpdatedAt),
            };
        }
    }

    private void Sort(string column)
    {
        if (_sortColumn == column)
            _sortDesc = !_sortDesc;
        else
        {
            _sortColumn = column;
            _sortDesc = column is "applied" or "followup" or "status";
        }
    }

    private string SortState(string column)
    {
        if (_sortColumn != column) return "";
        return _sortDesc ? "sort-desc" : "sort-asc";
    }

    private async Task QuickAdd()
    {
        if (_userId is null || string.IsNullOrWhiteSpace(_qCompany) || string.IsNullOrWhiteSpace(_qTitle))
            return;

        var job = new Job
        {
            UserId = _userId,
            Company = _qCompany.Trim(),
            Title = _qTitle.Trim(),
            Url = string.IsNullOrWhiteSpace(_qUrl) ? null : _qUrl.Trim(),
            Status = _qStatus,
            DateApplied = _qStatus >= JobStatus.Applied && _qStatus != JobStatus.Saved
                ? DateOnly.FromDateTime(DateTime.Today) : null,
            Location = string.IsNullOrWhiteSpace(_qLocation) ? null : _qLocation.Trim(),
            Salary = string.IsNullOrWhiteSpace(_qSalary) ? null : _qSalary.Trim(),
        };
        Db.Jobs.Add(job);
        await Db.SaveChangesAsync();

        _qCompany = _qTitle = _qUrl = "";
        _qStatus = JobStatus.Applied;
        _qLocation = _qSalary = null;
        ClearPaste();
        await LoadJobs();
        await Toast($"Added {job.Company}");
        await _quickCompanyRef.FocusAsync();
    }

    private async Task QuickAddKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await QuickAdd();
    }

    // ─── External job search (deep links) ──────────────────────────

    private static readonly (string Key, string Label)[] SearchProviders =
    [
        ("linkedin",  "LinkedIn"),
        ("indeed",    "Indeed"),
        ("wellfound", "Wellfound"),
        ("glassdoor", "Glassdoor"),
        ("google",    "Google Jobs"),
    ];

    private string BuildSearchUrl(string provider)
    {
        var q = Uri.EscapeDataString((_searchQuery ?? "").Trim());
        return provider switch
        {
            "linkedin"  => $"https://www.linkedin.com/jobs/search/?keywords={q}",
            "indeed"    => $"https://www.indeed.com/jobs?q={q}",
            "wellfound" => $"https://wellfound.com/jobs?q={q}",
            "glassdoor" => $"https://www.glassdoor.com/Job/jobs.htm?sc.keyword={q}",
            "google"    => $"https://www.google.com/search?q={q}+jobs&ibp=htl;jobs",
            _ => "#",
        };
    }

    // ─── Paste-to-extract ──────────────────────────────────────────

    private void ParsePaste()
    {
        _lastExtraction = JobPostingParser.Parse(_pasteText);
        if (!string.IsNullOrEmpty(_lastExtraction.Company)) _qCompany = _lastExtraction.Company;
        if (!string.IsNullOrEmpty(_lastExtraction.Title))   _qTitle   = _lastExtraction.Title;
        if (!string.IsNullOrEmpty(_lastExtraction.Url))     _qUrl     = _lastExtraction.Url;
        _qLocation = _lastExtraction.Location;
        _qSalary   = _lastExtraction.Salary;
    }

    private void ClearPaste()
    {
        _pasteText = "";
        _lastExtraction = null;
    }

    private void ClearExtras()
    {
        _qLocation = null;
        _qSalary = null;
    }

    private void ApplyPrefill()
    {
        var uri = new Uri(Nav.Uri);
        var q = QueryHelpers.ParseQuery(uri.Query);
        if (q.TryGetValue("prefill_text", out var t) && !string.IsNullOrWhiteSpace(t))
        {
            _pasteText = t.ToString();
            _pasteOpen = true;
            ParsePaste();
        }
        else
        {
            if (q.TryGetValue("prefill_url", out var u))     _qUrl = u.ToString();
            if (q.TryGetValue("prefill_title", out var ti))  _qTitle = ti.ToString();
            if (q.TryGetValue("prefill_company", out var c)) _qCompany = c.ToString();
        }
    }

    private void ToggleStatusMenu(int jobId)
    {
        _statusMenuJobId = _statusMenuJobId == jobId ? null : jobId;
        _pendingDeleteId = null;
    }

    private async Task SetStatus(Job job, JobStatus newStatus)
    {
        _statusMenuJobId = null;
        if (job.Status == newStatus) return;

        var tracked = await Db.Jobs.FirstAsync(j => j.Id == job.Id && j.UserId == _userId);
        tracked.Status = newStatus;
        tracked.UpdatedAt = DateTime.UtcNow;
        if (newStatus == JobStatus.Applied && tracked.DateApplied is null)
            tracked.DateApplied = DateOnly.FromDateTime(DateTime.Today);
        await Db.SaveChangesAsync();
        await LoadJobs();
        await Toast($"Marked {FormatStatus(newStatus)}");
    }

    private async Task OnFollowUpChanged(Job job, ChangeEventArgs e)
    {
        var tracked = await Db.Jobs.FirstAsync(j => j.Id == job.Id && j.UserId == _userId);
        if (DateOnly.TryParse(e.Value?.ToString(), out var d))
            tracked.FollowUpDate = d;
        else
            tracked.FollowUpDate = null;
        tracked.UpdatedAt = DateTime.UtcNow;
        await Db.SaveChangesAsync();
        await LoadJobs();
        await Toast(tracked.FollowUpDate is null ? "Follow-up cleared" : $"Follow-up set for {tracked.FollowUpDate:MMM d}");
    }

    private async Task SnoozeFollowUp(Job job, int days)
    {
        var tracked = await Db.Jobs.FirstAsync(j => j.Id == job.Id && j.UserId == _userId);
        var basis = tracked.FollowUpDate ?? DateOnly.FromDateTime(DateTime.Today);
        tracked.FollowUpDate = basis.AddDays(days);
        tracked.UpdatedAt = DateTime.UtcNow;
        await Db.SaveChangesAsync();
        await LoadJobs();
        await Toast($"Snoozed {days}d → {tracked.FollowUpDate:MMM d}");
    }

    private void Edit(Job job)
    {
        if (_editingId == job.Id)
        {
            CancelEdit();
            return;
        }
        _editingId = job.Id;
        _editJob = new Job
        {
            Id = job.Id,
            UserId = job.UserId,
            Company = job.Company,
            Title = job.Title,
            Location = job.Location,
            Salary = job.Salary,
            Url = job.Url,
            DateApplied = job.DateApplied,
            Status = job.Status,
            RecruiterName = job.RecruiterName,
            RecruiterEmail = job.RecruiterEmail,
            FollowUpDate = job.FollowUpDate,
            InterviewDate = job.InterviewDate,
            Notes = job.Notes,
        };
        _editInterviewDate = job.InterviewDate?.ToDateTime(TimeOnly.MinValue);
        _editAppliedDate = job.DateApplied?.ToDateTime(TimeOnly.MinValue);
    }

    private async Task SaveEdit()
    {
        if (_editJob is null) return;
        var tracked = await Db.Jobs.FirstAsync(j => j.Id == _editJob.Id && j.UserId == _userId);
        tracked.Location = _editJob.Location;
        tracked.Salary = _editJob.Salary;
        tracked.Url = _editJob.Url;
        tracked.RecruiterName = _editJob.RecruiterName;
        tracked.RecruiterEmail = _editJob.RecruiterEmail;
        tracked.Notes = _editJob.Notes;
        tracked.InterviewDate = _editInterviewDate.HasValue ? DateOnly.FromDateTime(_editInterviewDate.Value) : null;
        tracked.DateApplied = _editAppliedDate.HasValue ? DateOnly.FromDateTime(_editAppliedDate.Value) : null;
        tracked.UpdatedAt = DateTime.UtcNow;
        await Db.SaveChangesAsync();
        CancelEdit();
        await LoadJobs();
        await Toast("Saved");
    }

    private void CancelEdit()
    {
        _editingId = null;
        _editJob = null;
        _editInterviewDate = null;
        _editAppliedDate = null;
    }

    private void RequestDelete(Job job)
    {
        _pendingDeleteId = job.Id;
        _statusMenuJobId = null;
    }

    private async Task Delete(Job job)
    {
        if (_pendingDeleteId != job.Id)
        {
            _pendingDeleteId = job.Id;
            return;
        }
        var tracked = await Db.Jobs.FirstAsync(j => j.Id == job.Id && j.UserId == _userId);
        Db.Jobs.Remove(tracked);
        await Db.SaveChangesAsync();
        _pendingDeleteId = null;
        await LoadJobs();
        await Toast($"Deleted {job.Company}");
    }

    private string RowClass(Job j)
    {
        var classes = new List<string> { "job-row" };
        var today = DateOnly.FromDateTime(DateTime.Today);
        if (j.FollowUpDate.HasValue && j.FollowUpDate < today
            && j.Status != JobStatus.Rejected && j.Status != JobStatus.Offer && j.Status != JobStatus.Withdrawn)
            classes.Add("row-overdue");
        if (_editingId == j.Id) classes.Add("row-editing");
        return string.Join(' ', classes);
    }

    private static string FormatStatus(JobStatus s) => s switch
    {
        JobStatus.RecruiterMessaged => "Recruiter messaged",
        _ => s.ToString(),
    };

    private static string? FaviconUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return null;
        if (!Uri.TryCreate(url, UriKind.Absolute, out var u)) return null;
        return $"https://www.google.com/s2/favicons?domain={u.Host}&sz=32";
    }

    // ─── URL <-> state sync ─────────────────────────────────────────

    private void ReadQueryString()
    {
        var uri = new Uri(Nav.Uri);
        var q = QueryHelpers.ParseQuery(uri.Query);
        _search = q.TryGetValue("q", out var s) ? s.ToString() : "";
        _filterStatus = q.TryGetValue("status", out var st) ? st.ToString() : "";
    }

    private void UpdateQueryString()
    {
        var url = Nav.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["q"] = string.IsNullOrEmpty(_search) ? null : _search,
            ["status"] = string.IsNullOrEmpty(_filterStatus) ? null : _filterStatus,
        });
        if (!string.Equals(url, Nav.Uri, StringComparison.Ordinal))
        {
            Nav.NavigateTo(url, forceLoad: false, replace: true);
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var prevSearch = _search;
        var prevFilter = _filterStatus;
        ReadQueryString();
        if (prevSearch != _search || prevFilter != _filterStatus)
            InvokeAsync(StateHasChanged);
    }

    private async Task Toast(string message)
    {
        try { await JS.InvokeVoidAsync("jobtracker.toast", message); } catch { /* best-effort */ }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        _selfRef?.Dispose();
    }
}
